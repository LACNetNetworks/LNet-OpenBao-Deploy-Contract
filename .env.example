# RPC del nodo lnet/LACChain
LACCHAIN_RPC=http://<ip-de-tu-nodo-lnet>

# Writer node de lnet que aprueba las transacciones (modelo de gas LAC-NET)
NODE_ADDRESS=0x...

# trustedForwarder del modelo de gas (BaseRelayRecipient)
#   local / open-protestnet = 0xa4B5eE2906090ce2cDbf5dfff944db26f397037D
#   mainnet                  = 0xEAA5420AF59305c5ecacCB38fcDe70198001d147
TRUSTED_FORWARDER=0xEAA5420AF59305c5ecacCB38fcDe70198001d147

# Cuenta que firma: debe coincidir con la clave del bao (check-deployer lo valida)
DEPLOYER_ADDRESS=0x...

# OpenBao / Vault (plugin secp256k1)
BAO_ADDR=http://127.0.0.1:8200
BAO_TOKEN=
BAO_MOUNT=secp
